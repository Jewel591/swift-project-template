{
  "mcpServers": {
    "xcode": {
      "type": "stdio",
      "command": "xcrun",
      "args": [
        "mcpbridge"
      ],
      "env": {}
    },
    "revenuecat": {
      "type": "http",
      "url": "https://mcp.revenuecat.ai/mcp",
      "headers": {
        "Authorization": "Bearer <REVENUECAT_API_KEY>"
      }
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=<SUPABASE_PROJECT_REF>",
      "headers": {
        "Authorization": "Bearer <SUPABASE_API_KEY>"
      }
    }
  }
}